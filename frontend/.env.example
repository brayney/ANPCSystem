# Frontend Environment Variables Template
# Copy this file to .env.local and fill in the values

# API Configuration
# Set to your API root. Local backend routes are mounted under /api.
# Example: https://anpc-yard-backend-xxxxx.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# Optional: Build Configuration
# These are usually auto-detected by Create React App
REACT_APP_ENV=production
